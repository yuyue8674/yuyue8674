# ========================================
# GEO获客系统 - 环境变量配置模板
# ========================================
# 
# 使用说明：
# 1. 复制此文件为 .env.local
# 2. 填写真实的配置值
# 3. 在Vercel中配置相同的环境变量
#
# 注意：.env.local 文件不会提交到Git仓库
# ========================================

# ----------------------------------------
# 网站配置
# ----------------------------------------

# 网站URL（部署后修改为实际域名）
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# 网站名称
NEXT_PUBLIC_SITE_NAME=GEO获客系统

# ----------------------------------------
# AI搜索配置（豆包大模型）
# ----------------------------------------

# 豆包API密钥（必填）
# 获取地址：https://www.volcengine.com/
ARK_API_KEY=your-ark-api-key-here

# 豆包模型名称
ARK_MODEL=doubao-seed-2-0-pro-260215

# ----------------------------------------
# 数据库配置（可选，当前使用文件存储）
# ----------------------------------------

# PostgreSQL数据库URL（如果使用数据库）
# DATABASE_URL=postgresql://user:password@host:5432/database

# ----------------------------------------
# 对象存储配置（可选，用于存储企业Logo等）
# ----------------------------------------

# AWS S3 兼容对象存储
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_REGION=cn-north-1
# S3_BUCKET=your-bucket-name
# S3_ENDPOINT=https://s3.cn-north-1.amazonaws.com

# ----------------------------------------
# SEO配置
# ----------------------------------------

# 百度站长平台Token（用于提交sitemap）
BAIDU_ZIYUAN_TOKEN=your-baidu-token

# Google Search Console验证码
GOOGLE_SITE_VERIFICATION=your-google-verification-code

# ----------------------------------------
# 分析配置（可选）
# ----------------------------------------

# Google Analytics
# NEXT_PUBLIC_GA_ID=UA-XXXXXXXXX-X

# 百度统计
# NEXT_PUBLIC_BAIDU_TONGJI_ID=your-baidu-tongji-id
