{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "geo-customer-system",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "headers": {
        "Cache-Control": "no-store, must-revalidate"
      },
      "continue": true
    },
    {
      "src": "/show/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=3600, s-maxage=3600"
      },
      "continue": true
    },
    {
      "src": "/sitemap.xml",
      "headers": {
        "Content-Type": "application/xml"
      },
      "dest": "/api/export?format=sitemap"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    }
  ],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "regions": ["hnd1"],
  "framework": "nextjs",
  "buildCommand": "pnpm run build",
  "devCommand": "pnpm run dev",
  "installCommand": "pnpm install",
  "outputDirectory": ".next"
}
